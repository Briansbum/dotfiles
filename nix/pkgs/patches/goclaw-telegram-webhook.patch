+// WebhookHandler returns the webhook handler and route for mounting on the main gateway mux.
+// Only active when telegram connection_mode is set to "webhook".
+func (c *Channel) WebhookHandler() (string, http.Handler) {
+	mode := strings.ToLower(strings.TrimSpace(c.config.ConnectionMode))
+	if envMode := strings.ToLower(strings.TrimSpace(os.Getenv("GOCLAW_TELEGRAM_CONNECTION_MODE"))); envMode != "" {
+		mode = envMode
+	}
+	if mode == "" && strings.TrimSpace(os.Getenv("GOCLAW_TELEGRAM_WEBHOOK_URL")) != "" {
+		mode = "webhook"
+	}
+	if mode != "webhook" {
+		return "", nil
+	}
+	if c.webhookHandler == nil {
+		return "", nil
+	}
+	return c.webhookPath(), c.webhookHandler
+}
+
+func (c *Channel) webhookPath() string {
+	if c.config.WebhookPath != "" {
+		return "/" + strings.TrimPrefix(c.config.WebhookPath, "/")
+	}
+	if envPath := strings.TrimSpace(os.Getenv("GOCLAW_TELEGRAM_WEBHOOK_PATH")); envPath != "" {
+		return "/" + strings.TrimPrefix(envPath, "/")
+	}
+	return "/telegram/webhook"
+}
